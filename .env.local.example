# Copy to .env.local and fill in your values
CRON_SECRET=your-cron-secret-here
REFRESH_PASSWORD=your-refresh-password-here

# Required on Vercel for refresh/cron to persist data (create Blob store in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here
# Optional: "private" (default) or "public" — must match your Blob store access setting
BLOB_ACCESS=private
